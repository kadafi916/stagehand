<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Stagehand</title>
    <link rel="shortcut icon" href="{{root}}/static/new/img/favicon.ico">
    <link rel="stylesheet" href="{{root}}/static/new/css/semantic.min.css.gz">
    <link rel="stylesheet" href="{{root}}/static/new/css/stagehand.css">
    <style>
        /* Theme palette.  Dark is the default; body.theme-light overrides.
           The top nav intentionally stays dark in both themes. */
        :root {
            --bg: #1b1c1d;
            --text: #e0e0e0;
            --text-strong: #fff;
            --text-bright: #eee;
            --text-body: #ddd;
            --text-soft: #ccc;
            --muted: #888;
            --muted-soft: #aaa;
            --muted-dim: #666;
            --surface: #2d2d2d;
            --surface-2: #232323;
            --surface-3: #1e1e1e;
            --input-bg: #111;
            --border: #444;
            --border-soft: #333;
            --border-strong: #555;
            --hover: rgba(255,255,255,0.05);
            --hover-strong: rgba(255,255,255,0.08);
            --hover-stronger: rgba(255,255,255,0.12);
            --shadow: rgba(0,0,0,0.5);
            --shadow-strong: rgba(0,0,0,0.7);
        }
        body.theme-light {
            --bg: #f2f2f2;
            --text: #2a2a2a;
            --text-strong: #000;
            --text-bright: #222;
            --text-body: #333;
            --text-soft: #444;
            --muted: #777;
            --muted-soft: #666;
            --muted-dim: #999;
            --surface: #ffffff;
            --surface-2: #ebebeb;
            --surface-3: #ffffff;
            --input-bg: #fff;
            --border: #ccc;
            --border-soft: #ddd;
            --border-strong: #bbb;
            --hover: rgba(0,0,0,0.04);
            --hover-strong: rgba(0,0,0,0.07);
            --hover-stronger: rgba(0,0,0,0.1);
            --shadow: rgba(0,0,0,0.15);
            --shadow-strong: rgba(0,0,0,0.25);
        }
        body { background: var(--bg); color: var(--text); margin: 0; padding: 0; }
        #app-menu { box-shadow: 0 3px 20px rgba(0,0,0,0.8) !important; }
        /* Semantic UI inverted basic buttons are white-outline; fix for light bg */
        body.theme-light .ui.basic.inverted.button {
            color: #333 !important;
            box-shadow: 0 0 0 1px #999 inset !important;
        }
        body.theme-light .ui.basic.inverted.button:hover {
            color: #000 !important;
            box-shadow: 0 0 0 1px #666 inset !important;
        }
        #nav-theme-toggle { cursor: pointer; }
        .view { display: none; padding-top: 4.5rem; min-height: 100vh; }
        .view.active { display: block; }
        .view-inner { max-width: 1200px; margin: 0 auto; padding: 1.5rem 1rem; }

        /* Show banner grid */
        #shows-grid .column { padding: 0.5rem !important; cursor: pointer; }
        #shows-grid .banner-wrap {
            position: relative; overflow: hidden; border-radius: 4px;
            box-shadow: 0 2px 8px var(--shadow);
            transition: transform 0.15s, box-shadow 0.15s;
        }
        #shows-grid .banner-wrap:hover { transform: scale(1.02); box-shadow: 0 4px 16px var(--shadow-strong); }
        /* Banner images vary by provider (TheTVDB: wide banner, TVmaze: portrait
           poster) — normalize tile shape and crop to fit. */
        #shows-grid .banner-wrap img { width: 100%; display: block; aspect-ratio: 5.4 / 1; object-fit: cover; }
        #shows-grid .banner-wrap .status-badge {
            position: absolute; top: 6px; right: 6px;
            background: rgba(0,0,0,0.75); border-radius: 4px; padding: 2px 6px;
            font-size: 11px; font-weight: bold; letter-spacing: 0.5px;
        }
        #shows-grid .banner-wrap .needed-badge {
            position: absolute; bottom: 6px; right: 6px;
            background: rgba(219,40,40,0.9); border-radius: 4px; padding: 2px 7px;
            font-size: 11px; font-weight: bold; color: white;
        }
        #shows-grid .show-name {
            background: rgba(0,0,0,0.65); color: #eee; font-size: 12px;
            padding: 4px 8px; text-align: center;
        }

        /* Episode status colors */
        .status-have { color: #21ba45; }
        .status-need { color: #e03997; }
        .status-need-forced { color: #e03997; }
        .status-future { color: #767676; }
        .status-ignore { color: #767676; }

        /* Notifications */
        #notif-area { position: fixed; top: 4.2rem; right: 1rem; z-index: 9999; width: 320px; }
        .notif-item {
            background: var(--surface); border-left: 4px solid #21ba45;
            border-radius: 4px; padding: 10px 14px; margin-bottom: 8px;
            box-shadow: 0 2px 8px var(--shadow); animation: notif-in 0.2s ease;
        }
        .notif-item.error { border-color: #db2828; }
        .notif-item.warning { border-color: #f2711c; }
        .notif-item .notif-title { font-weight: bold; margin-bottom: 3px; }
        .notif-item .notif-close { float: right; cursor: pointer; opacity: 0.6; margin-left: 8px; }
        .notif-item .notif-close:hover { opacity: 1; }
        @keyframes notif-in { from { opacity:0; transform: translateX(20px); } to { opacity:1; transform:none; } }

        /* Episode table */
        .episode-table { width: 100%; }
        .episode-table td { padding: 6px 8px; vertical-align: middle; }
        .episode-table .ep-num { color: var(--muted); width: 3em; text-align: center; }
        .episode-table .ep-date { color: var(--muted); white-space: nowrap; width: 7em; }
        .episode-table .ep-status { width: 2.5em; text-align: center; }
        .episode-table tr:hover { background: var(--hover); cursor: pointer; }
        .ep-dot { cursor: pointer; }
        .ep-dot:hover { opacity: 0.75; }
        #ep-action-menu, #season-action-menu { position: fixed; background: var(--surface-3); border: 1px solid var(--border); border-radius: 4px;
            box-shadow: 0 4px 14px var(--shadow-strong); z-index: 9999; min-width: 190px; display: none; }
        #ep-action-menu .ep-menu-item, #season-action-menu .season-menu-item { padding: 9px 16px; cursor: pointer; font-size: 13px; border-bottom: 1px solid var(--border-soft); }
        #ep-action-menu .ep-menu-item:last-child, #season-action-menu .season-menu-item:last-child { border-bottom: none; }
        #ep-action-menu .ep-menu-item:hover, #season-action-menu .season-menu-item:hover { background: var(--hover-strong); }
        .season-menu-btn { font-size: 16px; color: var(--muted); padding: 0 4px 0 12px; line-height: 1; cursor: pointer; flex-shrink: 0; }
        .season-menu-btn:hover { color: var(--text-strong); }
        #nav-configure.nav-current { background: rgba(255,255,255,0.08) !important; }
        #nav-configure > .menu { display: none; position: absolute; top: 100%; left: 0;
            background: #2d2d2d; border: 1px solid #555; border-radius: 4px;
            min-width: 140px; z-index: 9999; box-shadow: 0 4px 14px rgba(0,0,0,0.7); }
        #nav-configure > .menu a.item { color: #ddd !important; display: block; padding: 10px 16px; }
        #nav-configure > .menu a.item:hover { background: rgba(255,255,255,0.1) !important; color: #fff !important; }
        #nav-search-input { color: #fff !important; }
        #nav-search-input::placeholder { color: rgba(255,255,255,0.5) !important; }
        .ui.modal { background: var(--surface-3) !important; color: var(--text-body) !important; }
        .ui.modal > .header { background: var(--surface-2) !important; color: var(--text-strong) !important; border-bottom: 1px solid var(--border) !important; }
        .ui.modal > .content { background: var(--surface-3) !important; color: var(--text-body) !important; }
        .ui.modal > .actions { background: var(--surface-2) !important; border-top: 1px solid var(--border) !important; }
        .season-header {
            background: var(--hover-strong); padding: 8px 14px;
            font-weight: bold; cursor: pointer; user-select: none;
            border-radius: 4px; margin: 0.5rem 0 0;
            display: flex; align-items: center; justify-content: space-between;
        }
        .season-header:hover { background: var(--hover-stronger); }
        .season-body { overflow: hidden; }

        /* Settings form */
        .settings-card { background:var(--surface); border-radius:6px; padding:1.5rem; margin-bottom:1rem; }
        .settings-card h3 { margin-top:0; margin-bottom:1rem; font-size:15px; color:var(--text-strong); }
        .settings-field { margin-bottom: 1rem; }
        .settings-field label { display: block; font-size: 12px; color: var(--muted-soft); margin-bottom: 4px; }
        .settings-field input[type=text],
        .settings-field input[type=password],
        .settings-field input[type=number],
        .settings-field select {
            background: var(--input-bg); border: 1px solid var(--border); color: var(--text-bright);
            border-radius: 4px; padding: 7px 10px; width: 100%; box-sizing: border-box;
        }
        .settings-radio-group { display: flex; gap: 8px; flex-wrap: wrap; }
        .settings-radio-group label {
            cursor: pointer; padding: 5px 14px; border-radius: 4px;
            border: 1px solid var(--border); background: var(--surface); color: var(--text-bright);
            font-size: 13px; transition: all 0.15s;
        }
        .settings-radio-group input { display: none; }
        .settings-radio-group input:checked + label { background: #2185d0; border-color: #2185d0; color: white; }

        /* Downloads */
        .dl-progress-bar { background: var(--border); border-radius: 3px; height: 8px; overflow: hidden; min-width: 100px; }
        .dl-progress-bar .fill { background: #21ba45; height: 100%; transition: width 0.3s; }
        .week-header { color: var(--muted); font-size: 13px; padding: 12px 0 4px; text-transform: uppercase; letter-spacing: 0.5px; }

        /* Search results */
        .search-result-item { padding: 10px 12px; cursor: pointer; border-bottom: 1px solid var(--border-soft); transition: background 0.1s; }
        .search-result-item:last-child { border-bottom: none; }
        .search-result-item:hover { background: var(--hover-strong); }
        .search-result-item.selected { background: rgba(33,133,208,0.2); }
        .search-result-item .result-name { font-weight: bold; }
        .search-result-item .result-meta { font-size: 12px; color: var(--muted); margin-top: 2px; }

        /* Themed table */
        .ui.table { background: transparent; color: var(--text-bright); border-color: var(--border-soft); }
        .ui.table thead th { background: var(--hover-strong); color: var(--text-soft); border-color: var(--border-soft); }
        .ui.table td { border-color: var(--border-soft); }
        .ui.table tr:hover td { background: var(--hover) !important; }

        /* Nav progress */
        #nav-progress-bar { margin: 0; min-width: 120px; }
        #nav-progress-bar .bar { min-width: 0 !important; }

        /* Show detail banner */
        #show-banner-img { width: 100%; max-height: 200px; object-fit: cover;
                           border-radius: 6px; display: block; margin-bottom: 1rem; }
        #show-detail-name { font-size: 1.8rem; font-weight: bold; margin-bottom: 0.25rem; }
        #show-overview { color: var(--muted-soft); font-size: 14px; margin-bottom: 1.5rem; line-height: 1.5; }

        /* Filter toggle */
        .filter-btn {
            padding: 6px 16px; border-radius: 4px; cursor: pointer;
            background: transparent; border: 1px solid var(--border-strong); color: var(--muted-soft);
            font-size: 13px; transition: all 0.15s;
        }
        .filter-btn.active { background: #2185d0; border-color: #2185d0; color: white; }
        .filter-btn:hover { border-color: var(--muted); color: var(--text-soft); }

        /* Utility text classes (theme-aware) */
        .text-muted { color: var(--muted) !important; }
        .text-soft { color: var(--muted-soft) !important; }
        .text-dim { color: var(--muted-dim) !important; }
        .themed-select {
            background: var(--surface); border: 1px solid var(--border); color: var(--text-bright);
            border-radius: 4px; padding: 5px 8px; margin: 0 4px;
        }
        .themed-panel { background: var(--hover); border-radius: 4px; }
        .themed-box { background: var(--surface); border: 1px solid var(--border); border-radius: 4px; }
        .themed-hr { border-bottom: 1px solid var(--border-soft); }
        /* Log console stays dark in both themes */
        #log-output { background: #0d0d0d; color: #ccc; }

        @media (max-width: 1000px) {
            #menu-label-upcoming, #menu-label-history, #menu-label-stats, #menu-label-downloads { display: none !important; }
        }
        @media (max-width: 600px) {
            #nav-progress, #menu-label-logo, #menu-label-configure { display: none !important; }
        }
        /* Stats dashboard */
        .stat-cards { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 1rem; }
        .stat-card { background: var(--surface); border-radius: 6px; padding: 1rem 1.25rem; flex: 1; min-width: 150px; }
        .stat-card .stat-value { font-size: 1.7rem; font-weight: bold; }
        .stat-card .stat-label { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; }
        .stat-card .stat-sub { font-size: 12px; color: var(--muted-soft); margin-top: 4px; }
        .bar-chart { display: flex; align-items: flex-end; gap: 2px; height: 120px; }
        .bar-chart .bar { flex: 1; background: #2185d0; border-radius: 2px 2px 0 0; min-height: 2px; position: relative; }
        .bar-chart .bar:hover { background: #1678c2; }
        .hbar { background: var(--hover-strong); border-radius: 3px; height: 10px; overflow: hidden; }
        .hbar .fill { background: #21ba45; height: 100%; }

        /* Upcoming — one table per day; fixed layout keeps columns aligned across tables */
        .upcoming-table { width: 100%; table-layout: fixed; }
        .upcoming-table td:nth-child(1) { width: 5.5em; }
        .upcoming-table td:nth-child(2) { width: 30%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .upcoming-table td:nth-child(3) { width: 6em; }
        .upcoming-table td:nth-child(4) { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

        /* Downloads — queue table + one table per week; same fixed layout treatment */
        .dl-table { width: 100%; table-layout: fixed; }
        .dl-table th:nth-child(1) { width: 28%; }
        .dl-table th:nth-child(2) { width: 4.5em; }
        .dl-table th:nth-child(4) { width: 8em; }
        .dl-table th:nth-child(5) { width: 14em; }
        .dl-table td:nth-child(1), .dl-table td:nth-child(3) { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        @media (max-width: 450px) {
            #menu-search { display: none; }
        }
    </style>
</head>
<body>
<script>
    // Apply saved theme immediately to avoid a flash of the wrong theme.
    if (localStorage.getItem('stagehand-theme') === 'light')
        document.body.className = 'theme-light';
</script>

<!-- ============================================================ TOP NAV -->
<div class="ui large inverted fixed menu" id="app-menu" style="background:#1a1a1a">
    <div class="menu" style="width:100%; flex-wrap:nowrap">
        <img src="{{root}}/static/new/img/masks.png" class="item header image"
             style="width:46px; padding:0; opacity:0.25; cursor:pointer" id="nav-logo">
        <div class="item header" id="menu-label-logo" style="opacity:0.25; padding-left:0; padding-right:1.5em; cursor:pointer">
            Stagehand
        </div>
        <a class="item active" data-view="tv" id="nav-tv" href="#/tv">
            <i class="film icon"></i> TV Shows
        </a>
        <a class="item" data-view="upcoming" id="nav-upcoming" href="#/upcoming">
            <i class="calendar icon"></i> <span id="menu-label-upcoming">Upcoming</span>
        </a>
        <a class="item" data-view="downloads" id="nav-downloads" href="#/downloads">
            <i class="download icon"></i> <span id="menu-label-downloads">Downloads</span>
        </a>
        <a class="item" data-view="history" id="nav-history" href="#/history">
            <i class="history icon"></i> <span id="menu-label-history">History</span>
        </a>
        <a class="item" data-view="stats" id="nav-stats" href="#/stats">
            <i class="bar chart icon"></i> <span id="menu-label-stats">Stats</span>
        </a>
        <div class="right menu" style="flex-shrink:0">
            <div class="ui dropdown item" id="nav-configure">
                <i class="setting icon"></i>
                <span id="menu-label-configure">Configure</span>
                <i class="dropdown icon"></i>
                <div class="menu">
                    <a class="item" data-view="settings" href="#/settings"><i class="settings icon"></i> Settings</a>
                    <a class="item" data-view="log" href="#/log"><i class="align justify icon"></i> Log</a>
                </div>
            </div>
            <a class="item" id="nav-theme-toggle" title="Toggle light/dark mode">
                <i class="sun icon" id="theme-toggle-icon"></i>
            </a>
            <div class="item" id="menu-search">
                <div class="ui transparent inverted icon input">
                    <input id="nav-search-input" placeholder="Search shows..." type="text">
                    <i class="search icon" style="cursor:pointer" id="nav-search-icon"></i>
                </div>
            </div>
            <div class="item" id="nav-progress" style="display:none">
                <div class="ui small teal progress" id="nav-progress-bar">
                    <div class="bar"><div class="progress"></div></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ============================================================ NOTIFICATIONS -->
<div id="notif-area"></div>

<!-- ============================================================ VIEW: TV -->
<div id="view-tv" class="view active">

    <!-- TV Library -->
    <div id="tv-library" class="view-inner">
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem; flex-wrap:wrap; gap:0.5rem">
            <div style="display:flex; gap:6px">
                <button class="filter-btn active" data-filter="all">All Shows</button>
                <button class="filter-btn" data-filter="active">Active Only</button>
                <button class="filter-btn" id="btn-lib-grid" title="Grid view" style="margin-left:12px"><i class="grid layout icon" style="margin:0"></i></button>
                <button class="filter-btn" id="btn-lib-list" title="List view"><i class="list layout icon" style="margin:0"></i></button>
            </div>
            <button class="ui primary button" id="btn-add-show">
                <i class="add icon"></i> Add TV Show
            </button>
        </div>
        <div class="ui two column doubling grid" id="shows-grid">
            <div class="column" style="text-align:center; padding:3rem 0">
                <div class="ui active inline loader"></div>
            </div>
        </div>
        <div id="shows-list" style="display:none"></div>
    </div>

    <!-- Add Show -->
    <div id="tv-add" class="view-inner" style="display:none">
        <div style="display:flex; align-items:center; gap:1rem; margin-bottom:1.5rem">
            <button class="ui button basic inverted" id="btn-back-library">
                <i class="arrow left icon"></i> Back
            </button>
            <h2 style="margin:0">Add TV Series</h2>
        </div>
        <div class="ui action input" style="width:100%; max-width:500px; margin-bottom:1rem">
            <input type="text" id="add-search-input" placeholder="Search by series name...">
            <button class="ui button primary" id="add-search-btn">Search</button>
        </div>
        <div id="add-results-wrap" style="display:none; max-width:600px">
            <div id="add-results-list" class="themed-box" style="margin-bottom:1rem"></div>
            <button class="ui primary button" id="btn-add-selected" disabled>
                <i class="add icon"></i> Add Selected Series
            </button>
        </div>
        <div id="add-loading" style="display:none; padding:2rem">
            <div class="ui active inline loader"></div>
            <span class="text-soft" style="margin-left:1rem">Searching...</span>
        </div>
    </div>

    <!-- Show Detail -->
    <div id="tv-show-detail" class="view-inner" style="display:none">
        <div style="display:flex; align-items:center; gap:1rem; margin-bottom:1rem">
            <button class="ui button basic inverted" id="btn-back-from-show">
                <i class="arrow left icon"></i> Library
            </button>
            <div>
                <div id="show-detail-name"></div>
                <div id="show-detail-status" class="text-muted" style="font-size:13px"></div>
            </div>
        </div>
        <img id="show-banner-img" src="" alt="" style="display:none">
        <div id="show-overview"></div>

        <div style="display:flex; flex-wrap:wrap; gap:1.5rem; margin-bottom:1rem">
            <div class="settings-field" style="flex:1; min-width:200px">
                <label>Quality</label>
                <div class="settings-radio-group" id="show-quality-group"></div>
                <div id="show-quality-hint" class="text-dim" style="font-size:11px; margin-top:5px"></div>
            </div>
            <div class="settings-field" style="flex:1; min-width:200px">
                <label>Episode Identifier</label>
                <div class="settings-radio-group" id="show-identifier-group"></div>
            </div>
            <div class="settings-field" style="min-width:150px">
                <label>Downloads Paused</label>
                <label style="cursor:pointer; display:flex; align-items:center; gap:8px; padding:5px 0">
                    <input type="checkbox" id="show-paused-cb" style="width:auto">
                    <span id="show-paused-label">No</span>
                </label>
            </div>
            <div class="settings-field" style="min-width:150px">
                <label>Flatten Seasons</label>
                <label style="cursor:pointer; display:flex; align-items:center; gap:8px; padding:5px 0">
                    <input type="checkbox" id="show-flat-cb" style="width:auto">
                    <span id="show-flat-label">No</span>
                </label>
            </div>
            <div class="settings-field" style="min-width:150px">
                <label>No Show Folder</label>
                <label style="cursor:pointer; display:flex; align-items:center; gap:8px; padding:5px 0">
                    <input type="checkbox" id="show-nosubdir-cb" style="width:auto">
                    <span id="show-nosubdir-label">No</span>
                </label>
                <div class="text-dim" style="font-size:11px; margin-top:2px">Save directly in TV root</div>
            </div>
        </div>

        <div id="show-advanced-toggle" class="season-header" style="margin-bottom:0.5rem">
            <span>Advanced Settings</span>
            <i class="chevron right icon" id="show-adv-icon"></i>
        </div>
        <div id="show-advanced" class="themed-panel" style="display:none; padding:1rem; margin-bottom:1rem">
            <div style="display:flex; flex-wrap:wrap; gap:1rem">
                <div class="settings-field" style="flex:1; min-width:180px">
                    <label>Provider</label>
                    <div class="settings-radio-group" id="show-provider-group"></div>
                </div>
                <div class="settings-field" style="flex:1; min-width:180px">
                    <label>Directory Name (blank for default)</label>
                    <input type="text" id="show-path-input">
                </div>
                <div class="settings-field" style="flex:1; min-width:180px">
                    <label>Search String Override</label>
                    <input type="text" id="show-search-string-input">
                </div>
                <div class="settings-field" style="flex:1; min-width:180px">
                    <label>Language Code</label>
                    <input type="text" id="show-language-input">
                </div>
                <div class="settings-field" style="flex:1; min-width:180px">
                    <label>Season Offset</label>
                    <input type="number" id="show-season-offset-input" step="1" value="0">
