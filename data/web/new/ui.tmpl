<!-- ============================================================ SCRIPTS -->
<script src="{{root}}/static/new/js/jquery-2.1.3.min.js.gz"></script>
<script src="{{root}}/static/new/js/semantic.min.js.gz"></script>
<script>
(function() {
'use strict';

var ROOT = '{{root}}';
var INITIAL_ASYNC = {{!json(asyncdata)}};

// ---------------------------------------------------------------- Stagehand class
function Stagehand(root) {
    this.root = root;
    this.jobs = {};
    this.timer = null;
    this.interval = 0;
    this.min_interval = 5000;
    this.max_interval = 10000;
    this.handlers = {};
    this.poll(this.min_interval);
}

Stagehand.prototype.bind = function(ntype, f) {
    if (!this.handlers[ntype]) this.handlers[ntype] = [];
    this.handlers[ntype].push(f);
};

Stagehand.prototype.api = function(url, data, type) {
    var self = this;
    data = data || {};
    type = (type || 'GET').toUpperCase();
    var dfd = $.Deferred();
    var xhr = $.ajax({ url: self.root + url, data: data, type: type })
        .done(function(response) {
            if (response.jobid == null) {
                response.xhr = xhr;
                dfd.resolve(response);
                return;
            }
            self.jobs[response.jobid] = [dfd, xhr];
            if (response.pending) dfd.notify(response.jobid);
            if (response.pending && self.interval > response.interval) {
                self.poll(response.interval);
            } else if (self.interval > 1000) {
                self.poll(1000);
            }
            self.handle_response(response);
        })
        .fail(function(jqxhr) {
            dfd.reject({ message: 'HTTP ' + jqxhr.status + ': ' + jqxhr.statusText, xhr: jqxhr });
        });
    return dfd.promise();
};

Stagehand.prototype.handle_response = function(response) {
    var self = this;
    var jobs = response.jobs || [];
    var notifications = response.notifications || [];
    var i, j, k, job, n;
    for (i = 0; i < jobs.length; i++) {
        job = jobs[i];
        if (self.jobs[job.id]) {
            var dfd = self.jobs[job.id][0], xhr = self.jobs[job.id][1];
            delete self.jobs[job.id];
            if (job.error) { job.error.xhr = xhr; dfd.reject(job.error); }
            else { dfd.resolve(job.result); }
        }
    }
    for (j = 0; j < notifications.length; j++) {
        n = notifications[j];
        if (self.handlers[n._ntype]) {
            for (k = 0; k < self.handlers[n._ntype].length; k++) {
                self.handlers[n._ntype][k](n);
            }
        }
        if (n._ntype === 'alert') {
            var ntype = n.type === 'error' ? 'error' : (n.type === 'warning' ? 'warning' : 'info');
            notify(n.title || '', n.text || '', ntype);
        }
    }
};

Stagehand.prototype.poll = function(interval) {
    var self = this;
    if (self.timer) {
        if (interval === self.interval) return;
        clearInterval(self.timer);
        self.timer = null;
    }
    self.interval = Math.min(interval != null ? interval : self.interval, self.max_interval);
    self.timer = setInterval(function() {
        var jobIds = Object.keys(self.jobs);
        var data = jobIds.length > 0 ? { jobs: jobIds.join(',') } : null;
        $.ajax({ url: self.root + '/api/jobs', data: data, timeout: self.interval })
            .done(function(r) {
                self.handle_response(r);
                if (Object.keys(self.jobs).length === 0 && (r.notifications || []).length === 0) {
                    if (self.interval < self.max_interval) self.poll(self.interval * 2);
                } else if (self.interval > self.min_interval) {
                    self.poll(self.min_interval);
                }
            })
            .fail(function() { self.poll(self.max_interval); });
    }, self.interval);
};

// ---------------------------------------------------------------- Notifications
function notify(title, text, type) {
    var $area = $('#notif-area');
    var cls = type === 'error' ? 'error' : (type === 'warning' ? 'warning' : '');
    var $n = $('<div>').addClass('notif-item ' + cls);
    var $close = $('<span>').addClass('notif-close').text('×');
    $n.append($close);
    if (title) $n.append($('<div>').addClass('notif-title').text(title));
    if (text) $n.append($('<div>').html(text));
    $close.on('click', function() { $n.fadeOut(200, function() { $n.remove(); }); });
    $area.append($n);
    setTimeout(function() { $n.fadeOut(400, function() { $n.remove(); }); }, 8000);
}

// ---------------------------------------------------------------- Upcoming
function loadUpcoming() {
    var days = $('#upcoming-days-select').val() || '14';
    $.get(ROOT + '/api/upcoming', { days: days }, function(data) {
        var $c = $('#upcoming-content').empty();
        var eps = data.episodes || [];
        if (!eps.length) {
            $c.html('<div class="text-muted" style="text-align:center;padding:3rem">Nothing scheduled in the next ' + data.days + ' days.</div>');
            return;
        }
        var todayStr = new Date().toISOString().slice(0, 10);
        var tomorrow = new Date(Date.now() + 86400000).toISOString().slice(0, 10);
        var lastDate = null, $tbl = null;
        eps.forEach(function(ep) {
            if (ep.airdate !== lastDate) {
                lastDate = ep.airdate;
                var label;
                if (ep.airdate === todayStr) label = 'Today';
                else if (ep.airdate === tomorrow) label = 'Tomorrow';
                else {
                    var d = new Date(ep.airdate + 'T00:00:00');
                    label = d.toLocaleDateString(undefined, { weekday: 'long', month: 'long', day: 'numeric' });
                }
                $c.append($('<div>').addClass('week-header').text(label));
                $tbl = $('<table>').addClass('ui table upcoming-table');
                $c.append($tbl);
            }
            var $tr = $('<tr>');
            if (ep.ignored) $tr.css('opacity', 0.45);
            $tr.append($('<td>').text(ep.airtime || ''));
            $tr.append($('<td>').append($('<a>').attr('href', '#/tv/' + ep.show_id).css('color', '#2185d0').attr('title', ep.show_name).text(ep.show_name)));
            $tr.append($('<td>').text(ep.code));
            $tr.append($('<td>').attr('title', ep.name).text(ep.name + (ep.ignored ? ' (ignored)' : '')));
            $tbl.append($tr);
        });
    });
}

// ---------------------------------------------------------------- History
function fmtSize(bytes) {
    if (!bytes) return '';
    if (bytes >= 1024 * 1024 * 1024) return (bytes / 1024 / 1024 / 1024).toFixed(2) + ' GB';
    return Math.round(bytes / 1024 / 1024) + ' MB';
}

function loadHistory() {
    $.get(ROOT + '/api/history', { limit: 500 }, function(data) {
        var $c = $('#history-content').empty();
        var recs = data.records || [];
        if (!recs.length) {
            $c.html('<div class="text-muted" style="text-align:center;padding:3rem">No downloads recorded yet. History starts accumulating from now on.</div>');
            return;
        }
        var $tbl = $('<table>').addClass('ui table');
        var $thead = $('<thead>').append($('<tr>')
            .append($('<th>').text('When'))
            .append($('<th>').text('Show'))
            .append($('<th>').text('Episode'))
            .append($('<th>').text('Title'))
            .append($('<th>').text('Quality'))
            .append($('<th>').text('Size')));
        $tbl.append($thead);
        var $tbody = $('<tbody>');
        recs.forEach(function(r) {
            var when = (r.ts || '').replace('T', ' ').slice(0, 16);
            var $tr = $('<tr>').css('cursor', 'pointer').attr('title', 'Click for details');
            $tr.append($('<td>').css('white-space', 'nowrap').text(when));
            $tr.append($('<td>').append($('<a>').attr('href', '#/tv/' + r.show_id).css('color', '#2185d0')
                .on('click', function(e) { e.stopPropagation(); }).text(r.show)));
            $tr.append($('<td>').text(r.code));
            $tr.append($('<td>').text(r.title));
            $tr.append($('<td>').text(r.quality));
            $tr.append($('<td>').css('white-space', 'nowrap').text(fmtSize(r.size)));
            var $dtr = $('<tr>').hide();
            var $dtd = $('<td>').attr('colspan', 6).css({ fontSize: '12px', lineHeight: '1.7' });
            function drow(label, value) {
                if (!value) return;
                $dtd.append($('<div>')
                    .append($('<span>').addClass('text-muted').css({ display: 'inline-block', width: '110px' }).text(label))
                    .append($('<span>').css('word-break', 'break-all').text(value)));
            }
            drow('Original file', r.original_filename);
            drow('Saved as', r.filename !== r.original_filename ? r.filename : null);
            drow('Picked because', r.reason);
            drow('Candidates', r.candidates ? 'chosen from ' + r.candidates + ' result' + (r.candidates !== 1 ? 's' : '') : null);
            drow('Source', r.searcher);
            if (!$dtd.children().length) drow('Details', 'Not recorded (downloaded before 0.4.21)');
            $dtr.append($dtd);
            $tr.on('click', function() { $dtr.toggle(); });
            $tbody.append($tr).append($dtr);
        });
        $tbl.append($tbody);
        $c.append($tbl);
    });
}

// ---------------------------------------------------------------- Stats
function loadStats() {
    $.get(ROOT + '/api/stats', function(d) {
        var $c = $('#stats-content').empty();

        var $cards = $('<div>').addClass('stat-cards');
        function card(value, label, sub) {
            var $card = $('<div>').addClass('stat-card');
            $card.append($('<div>').addClass('stat-value').text(value));
            $card.append($('<div>').addClass('stat-label').text(label));
            if (sub) $card.append($('<div>').addClass('stat-sub').text(sub));
            return $card;
        }
        var s = d.shows || {};
        $cards.append(card(d.shows_total || 0, 'Shows',
            (s.running || 0) + ' running, ' + (s.ended || 0) + ' ended' + (s.paused ? ', ' + s.paused + ' paused' : '')));
        var e = d.episodes || {};
        $cards.append(card(e.have || 0, 'Episodes Downloaded',
            (e.needed || 0) + ' needed, ' + (e.future || 0) + ' upcoming'));
        $cards.append(card(d.downloads_total || 0, 'Downloads Recorded',
            d.downloads_bytes ? fmtSize(d.downloads_bytes) + ' total' : 'since history began'));
        if (d.disk) {
            $cards.append(card(d.disk.free_gb + ' GB', 'Free on TV Dir',
                d.disk.used_pct + '% of ' + d.disk.total_gb + ' GB used'));
        }
        $c.append($cards);

        // Downloads per day, last 30 days
        var $chartCard = $('<div>').addClass('settings-card');
        $chartCard.append($('<h3>').text('Downloads — Last 30 Days'));
        var $chart = $('<div>').addClass('bar-chart');
        var daily = d.downloads_daily || {};
        var max = 1;
        var days = [];
        for (var i = 29; i >= 0; i--) {
            var day = new Date(Date.now() - i * 86400000).toISOString().slice(0, 10);
            var count = daily[day] || 0;
            if (count > max) max = count;
            days.push([day, count]);
        }
        days.forEach(function(pair) {
            var $bar = $('<div>').addClass('bar')
                .css('height', Math.round(100 * pair[1] / max) + '%')
                .attr('title', pair[0] + ': ' + pair[1] + ' download' + (pair[1] !== 1 ? 's' : ''));
            if (!pair[1]) $bar.css('background', 'var(--hover-strong)');
            $chart.append($bar);
        });
        $chartCard.append($chart);
        $c.append($chartCard);

        // Top shows
        var per = d.per_show || [];
        if (per.length) {
            var $topCard = $('<div>').addClass('settings-card');
            $topCard.append($('<h3>').text('Episodes by Show'));
            var maxHave = Math.max.apply(null, per.map(function(p) { return p.have; }).concat([1]));
            per.forEach(function(p) {
                var $row = $('<div>').css({ display: 'flex', alignItems: 'center', gap: '10px', marginBottom: '7px' });
                $row.append($('<a>').attr('href', '#/tv/' + p.id).css({ color: '#2185d0', width: '220px', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap', flexShrink: 0 }).text(p.name));
                var $bar = $('<div>').addClass('hbar').css('flex', '1');
                $bar.append($('<div>').addClass('fill').css('width', Math.round(100 * p.have / maxHave) + '%'));
                $row.append($bar);
                $row.append($('<span>').addClass('text-muted').css({ width: '70px', fontSize: '12px', textAlign: 'right', flexShrink: 0 }).text(p.have + ' / ' + p.total));
                $topCard.append($row);
            });
            $c.append($topCard);
        }
    });
}

// ---------------------------------------------------------------- Router
var stagehand;
var libraryLoaded = false;
var selectedSearchResult = null;

function navigate(path) {
    window.location.hash = path;
}

function route() {
    var hash = window.location.hash.slice(1) || '/tv';
    if (hash.charAt(0) !== '/') hash = '/' + hash;
    var parts = hash.replace(/^\//, '').split('/');
    var view = parts[0] || 'tv';

    if (view === 'tv') {
        var sub = parts[1] || '';
        showView('tv');
        if (sub === 'add') {
            showTvPage('add');
        } else if (sub && sub !== 'library') {
            var id = parts.slice(1).join('/');
            loadShowDetail(id);
        } else {
            showTvPage('library');
        }
    } else if (view === 'downloads') {
        showView('downloads');
        loadDownloads();
    } else if (view === 'upcoming') {
        showView('upcoming');
        loadUpcoming();
    } else if (view === 'history') {
        showView('history');
        loadHistory();
    } else if (view === 'stats') {
        showView('stats');
        loadStats();
    } else if (view === 'settings') {
        showView('settings');
    } else if (view === 'log') {
        showView('log');
    } else {
        showView('tv');
        showTvPage('library');
    }
}

function showView(view) {
    $('.view').removeClass('active');
    $('#view-' + view).addClass('active');
    $('a.item[data-view]').removeClass('active');
    $('a.item[data-view="' + view + '"]').addClass('active');
    if (view === 'settings' || view === 'log') {
        $('#nav-configure').addClass('nav-current');
    } else {
        $('#nav-configure').removeClass('nav-current');
    }
    if (view === 'log') {
        startLogStream();
    } else {
        stopLogStream();
    }
    if (view === 'downloads') {
        startDlPoll();
    } else {
        stopDlPoll();
    }
}

function showTvPage(page) {
    $('#tv-library, #tv-add, #tv-show-detail').hide();
    if (page === 'library') {
        $('#tv-library').show();
        loadLibrary();
    } else if (page === 'add') {
        $('#tv-add').show();
        setTimeout(function() { $('#add-search-input').focus(); }, 50);
    } else if (page === 'show') {
        $('#tv-show-detail').show();
    }
}

// ---------------------------------------------------------------- TV Library
var libraryShows = null;
var listSortKey = 'name', listSortDir = 1;

function loadLibrary() {
    if (libraryLoaded) { renderLibraryView(); return; }
    var savedFilter = localStorage.getItem('showsFilter') || 'all';
    $('.filter-btn[data-filter]').removeClass('active');
    $('.filter-btn[data-filter="' + savedFilter + '"]').addClass('active');

    $.get(ROOT + '/api/shows', function(data) {
        libraryShows = data.shows || [];
        libraryLoaded = true;
        renderLibraryView();
    }).fail(function() {
        notify('Error', 'Failed to load TV library.', 'error');
    });
}

function renderLibraryView() {
    var mode = localStorage.getItem('libraryView') || 'grid';
    $('#btn-lib-grid').toggleClass('active', mode === 'grid');
    $('#btn-lib-list').toggleClass('active', mode === 'list');
    if (mode === 'list') {
        $('#shows-grid').hide();
        $('#shows-list').show();
        renderLibraryList(libraryShows || []);
    } else {
        $('#shows-list').hide();
        $('#shows-grid').show();
        renderLibrary(libraryShows || []);
    }
}

function renderLibraryList(shows) {
    var $c = $('#shows-list').empty();
    var filter = localStorage.getItem('showsFilter') || 'all';
    var visible = shows.filter(function(s) {
        return filter !== 'active' || (s.status === 'running' && !s.paused);
    });
    if (!visible.length) {
        $c.html('<div class="text-muted" style="text-align:center;padding:3rem">No shows to display.</div>');
        return;
    }
    var cols = [
        ['name', 'Name'], ['status', 'Status'], ['have', 'Downloaded'],
        ['needed', 'Needed'], ['next_airdate', 'Next Episode'],
    ];
    visible.sort(function(a, b) {
        var av = a[listSortKey], bv = b[listSortKey];
        if (av == null) return 1;
        if (bv == null) return -1;
        if (typeof av === 'string') { av = av.toLowerCase(); bv = String(bv).toLowerCase(); }
        return (av < bv ? -1 : av > bv ? 1 : 0) * listSortDir;
    });
    var $tbl = $('<table>').addClass('ui table');
    var $hr = $('<tr>');
    cols.forEach(function(col) {
        var arrow = listSortKey === col[0] ? (listSortDir > 0 ? ' ▴' : ' ▾') : '';
        var $th = $('<th>').css('cursor', 'pointer').text(col[1] + arrow);
        $th.on('click', function() {
            if (listSortKey === col[0]) listSortDir = -listSortDir;
            else { listSortKey = col[0]; listSortDir = 1; }
            renderLibraryList(shows);
        });
        $hr.append($th);
    });
    $tbl.append($('<thead>').append($hr));
    var $tbody = $('<tbody>');
    var statusLabels = { running: 'Running', ended: 'Ended', suspended: 'Suspended', paused: 'Paused', unknown: '' };
    visible.forEach(function(s) {
        var $tr = $('<tr>').css('cursor', 'pointer');
        $tr.append($('<td>').append($('<a>').attr('href', '#/tv/' + s.id).css('color', '#2185d0').text(s.name)));
        $tr.append($('<td>').text(s.paused ? 'Paused' : (statusLabels[s.status] || '')));
        $tr.append($('<td>').text(s.have + ' / ' + s.total));
        $tr.append($('<td>').text(s.needed || ''));
        $tr.append($('<td>').text(s.next_airdate || ''));
        (function(id) { $tr.on('click', function() { navigate('/tv/' + id); }); })(s.id);
        $tbody.append($tr);
    });
    $tbl.append($tbody);
    $c.append($tbl);
}

function renderLibrary(shows) {
    var $grid = $('#shows-grid').empty();
    if (shows.length === 0) {
        $grid.append('<div class="column text-muted" style="text-align:center; padding:3rem 0"><a href="#/tv/add" style="color:#2185d0">Add your first TV series!</a></div>');
        libraryLoaded = true;
        return;
    }

    var filter = localStorage.getItem('showsFilter') || 'all';
    for (var i = 0; i < shows.length; i++) {
        var show = shows[i];
        var isActive = (show.status === 'running' && !show.paused);
        var $col = $('<div>').addClass('column').attr('data-show-id', show.id).attr('data-active', String(isActive));

        var $wrap = $('<div>').addClass('banner-wrap');
        var $img = $('<img>').attr('alt', show.name);
        $img.attr('src', ROOT + '/api/shows/' + encodeURIComponent(show.id) + '/banner');
        (function($i) {
            $i.on('error', function() { $(this).hide(); });
        })($img);
        $wrap.append($img);

        if (show.paused) {
            $wrap.append($('<span>').addClass('status-badge').css('color', '#f2711c').text('PAUSED'));
        } else if (show.status === 'ended') {
            $wrap.append($('<span>').addClass('status-badge').css('color', '#767676').text('ENDED'));
        } else if (show.status === 'suspended') {
            $wrap.append($('<span>').addClass('status-badge').css('color', '#f2711c').text('SUSPENDED'));
        }
        if (show.needed > 0) {
            $wrap.append($('<span>').addClass('needed-badge').text(show.needed + ' needed'));
        }
        $wrap.append($('<div>').addClass('show-name').text(show.name));
        $col.append($wrap);

        (function(showId) {
            $col.on('click', function() { navigate('/tv/' + showId); });
        })(show.id);

        if (filter === 'active' && !isActive) $col.hide();
        $grid.append($col);
    }
    libraryLoaded = true;
}

function setFilter(filter) {
    localStorage.setItem('showsFilter', filter);
    $('.filter-btn[data-filter]').removeClass('active');
    $('.filter-btn[data-filter="' + filter + '"]').addClass('active');
    if (libraryLoaded) renderLibraryView();
}

function setLibraryView(mode) {
    localStorage.setItem('libraryView', mode);
    if (libraryLoaded) renderLibraryView();
}

// ---------------------------------------------------------------- Add Show
function initAddShow() {
    $('#add-search-input').on('keydown', function(e) {
        if (e.keyCode === 13) $('#add-search-btn').click();
    });

    $('#add-search-btn').on('click', function() {
        var name = $('#add-search-input').val().trim();
        if (!name) return;
        selectedSearchResult = null;
        $('#btn-add-selected').prop('disabled', true);
        $('#add-results-wrap').hide();
        $('#add-loading').show();

        stagehand.api('/api/shows/search', { name: name })
            .done(function(data) {
                $('#add-loading').hide();
                renderSearchResults(data.results || [], name);
            })
            .fail(function(err) {
                $('#add-loading').hide();
                notify('Search Failed', err.message, 'error');
            });
    });

    $('#btn-add-selected').on('click', function() {
        if (!selectedSearchResult) return;
        var id = selectedSearchResult.id;
        $(this).prop('disabled', true);
        stagehand.api('/api/shows/' + encodeURIComponent(id), {}, 'PUT')
            .done(function() {
                libraryLoaded = false;
                navigate('/tv/' + id);
            })
            .fail(function(err) {
                $('#btn-add-selected').prop('disabled', false);
                notify('Add Failed', err.message, 'error');
            });
    });
}

function renderSearchResults(results, query) {
    var $list = $('#add-results-list').empty();
    if (results.length === 0) {
        $list.append($('<div>').css({ padding: '1rem', color: '#888' }).text('No results found for "' + query + '"'));
        $('#add-results-wrap').show();
        return;
    }
    for (var i = 0; i < results.length; i++) {
        var r = results[i];
        var $item = $('<div>').addClass('search-result-item');
        var year = r.started ? String(r.started).substring(0, 4) : '?';
        $item.append($('<div>').addClass('result-name').text(r.name));
        var metaText = year + ' • ' + r.provider;
        if (r.overview) metaText += ' • ' + r.overview.substring(0, 100) + '...';
        $item.append($('<div>').addClass('result-meta').text(metaText));
        (function(result) {
            $item.on('click', function() {
                $('.search-result-item').removeClass('selected');
                $(this).addClass('selected');
                selectedSearchResult = result;
                $('#btn-add-selected').prop('disabled', false);
            });
        })(r);
        $list.append($item);
    }
    $('#add-results-wrap').show();
}

// ---------------------------------------------------------------- Show Detail
function loadShowDetail(id) {
    showTvPage('show');
    $('#show-seasons').html('<div style="text-align:center; padding:2rem"><div class="ui active inline loader"></div></div>');
    $('#show-banner-img').hide();
    $('#show-detail-name').text('Loading...');
    $('#show-overview').text('');

    $.get(ROOT + '/api/shows/' + encodeURIComponent(id) + '/detail', function(show) {
        renderShowDetail(show);
    }).fail(function() {
        notify('Error', 'Failed to load show details.', 'error');
        navigate('/tv');
    });
}

function renderShowDetail(show) {
    $('#show-detail-name').text(show.name);

    var statusLabels = { running: 'Running', ended: 'Ended', suspended: 'Suspended', paused: 'Paused', unknown: '' };
    $('#show-detail-status').text(show.paused ? 'Paused' : (statusLabels[show.run_status] || ''));
    $('#show-overview').text(show.overview || '');

    var $img = $('#show-banner-img');
    $img.attr('src', ROOT + '/api/shows/' + encodeURIComponent(show.id) + '/banner')
        .off('error').on('error', function() { $(this).hide(); }).show();

    // Quality radios
    var $qg = $('#show-quality-group').empty();
    (show.quality_options || []).forEach(function(q) {
        var uid = 'q-' + q.replace(/\s/g,'_');
        $qg.append($('<input>').attr({ type:'radio', name:'show-quality', id:uid, value:q }).prop('checked', q === show.quality));
        $qg.append($('<label>').attr('for', uid).text(q));
    });

    // Explain what the selected tier concretely means for this show's runtime.
    function updateQualityHint() {
        var tier = $('input[name="show-quality"]:checked').val();
        var info = (show.quality_info || {})[tier];
        if (!info) { $('#show-quality-hint').text(''); return; }
        $('#show-quality-hint').text(
            'Accepts ' + info.resolutions + ' · rejects files under ' + fmtSize(info.min_mb * 1048576) +
            ' · ideal ~' + fmtSize(info.ideal_mb * 1048576) + ' (based on ' + info.runtime + ' min runtime)');
    }
    updateQualityHint();
    $('#tv-show-detail').off('change.qualhint').on('change.qualhint', 'input[name="show-quality"]', updateQualityHint);

    // Identifier radios
    var identLabels = { epcode: 'Episode Code', date: 'Air Date' };
    var $ig = $('#show-identifier-group').empty();
    (show.identifier_options || []).forEach(function(ident) {
        var uid = 'ident-' + ident;
        $ig.append($('<input>').attr({ type:'radio', name:'show-identifier', id:uid, value:ident }).prop('checked', ident === show.identifier));
        $ig.append($('<label>').attr('for', uid).text(identLabels[ident] || ident));
    });

    $('#show-paused-cb').prop('checked', show.paused);
    $('#show-paused-label').text(show.paused ? 'Yes' : 'No');
    $('#show-flat-cb').prop('checked', show.flat);
    $('#show-flat-label').text(show.flat ? 'Yes' : 'No');
    $('#show-nosubdir-cb').prop('checked', show.no_subdir);
    $('#show-nosubdir-label').text(show.no_subdir ? 'Yes' : 'No');
    $('#show-path-input').val(show.path || '');
    $('#show-search-string-input').val(show.search_string || '');
    $('#show-season-offset-input').val(show.season_offset || 0);
    $('#show-language-input').val(show.language || '');

    // Provider radios
    var $pg = $('#show-provider-group').empty();
    (show.providers || []).forEach(function(p) {
        var uid = 'prov-' + p.name;
        $pg.append($('<input>').attr({ type:'radio', name:'show-provider', id:uid, value:p.name }).prop('checked', p.name === show.provider));
        $pg.append($('<label>').attr('for', uid).text(p.label));
    });

    // Save settings on any change
    $('#tv-show-detail').off('change.settings').on('change.settings',
        'input[name="show-quality"], input[name="show-identifier"], #show-paused-cb, #show-flat-cb, #show-nosubdir-cb',
        function() {
            if (this.id === 'show-paused-cb') $('#show-paused-label').text(this.checked ? 'Yes' : 'No');
            if (this.id === 'show-flat-cb') $('#show-flat-label').text(this.checked ? 'Yes' : 'No');
            if (this.id === 'show-nosubdir-cb') $('#show-nosubdir-label').text(this.checked ? 'Yes' : 'No');
            saveShowSettings(show.id).fail(function(err) { notify('Save Failed', err.message, 'error'); });
        });
    $('#btn-save-adv-settings').off('click').on('click', function() {
        var $st = $('#show-adv-save-status');
        saveShowSettings(show.id)
            .done(function() { $st.css('color', '#4caf50').text('Saved'); setTimeout(function() { $st.text(''); }, 3000); })
            .fail(function() { $st.css('color', '#f44336').text('Save failed'); });
    });
    $('#tv-show-detail').off('change.provider').on('change.provider', 'input[name="show-provider"]', function() {
        stagehand.api('/api/shows/' + encodeURIComponent(show.id) + '/provider', { provider: this.value }, 'POST')
            .done(function() { loadShowDetail(show.id); })
            .fail(function(err) { notify('Provider Change Failed', err.message, 'error'); });
    });

    // Delete button
    $('#btn-show-delete').off('click').on('click', function() {
        $('#modal-delete-name').text(show.name);
        $('#modal-delete-confirm').off('click').on('click', function() {
            $('#modal-delete').modal('hide');
            stagehand.api('/api/shows/' + encodeURIComponent(show.id), {}, 'DELETE')
                .done(function() { libraryLoaded = false; navigate('/tv'); })
                .fail(function(err) { notify('Delete Failed', err.message, 'error'); });
        });
        $('#modal-delete').modal('show');
    });

    // Refresh button
    $('#btn-show-refresh').off('click').on('click', function() {
        var $b = $(this).prop('disabled', true).text('Refreshing...');
        stagehand.api('/api/shows/' + encodeURIComponent(show.id) + '/refresh', {}, 'POST')
            .always(function() { $b.prop('disabled', false).html('<i class="refresh icon"></i> Refresh Metadata'); })
            .done(function() { loadShowDetail(show.id); notify('Refreshed', show.name + ' updated.', 'info'); })
            .fail(function(err) { notify('Refresh Failed', err.message, 'error'); });
    });

    // Download needed button
    $('#btn-show-search-now').off('click').on('click', function() {
        var $b = $(this).prop('disabled', true);
        stagehand.api('/api/shows/check', { id: show.id })
            .always(function() { $b.prop('disabled', false); })
            .done(function(r) { notify('Search Done', 'Need: ' + (r.need||0) + ', Found: ' + (r.found||0), 'info'); })
            .fail(function(err) { notify('Search Failed', err.message, 'error'); });
    });

    renderSeasons(show.seasons || [], show.id);
}

function saveShowSettings(showId) {
    var settings = {
        quality: $('input[name="show-quality"]:checked').val() || '',
        identifier: $('input[name="show-identifier"]:checked').val() || '',
        paused: $('#show-paused-cb').is(':checked') ? 'true' : 'false',
        flat: $('#show-flat-cb').is(':checked') ? 'true' : 'false',
        no_subdir: $('#show-nosubdir-cb').is(':checked') ? 'true' : 'false',
        path: $('#show-path-input').val(),
        search_string: $('#show-search-string-input').val(),
        language: $('#show-language-input').val(),
        season_offset: parseInt($('#show-season-offset-input').val(), 10) || 0
    };
    return stagehand.api('/api/shows/' + encodeURIComponent(showId) + '/settings', settings, 'POST');
}

// ---------------------------------------------------------------- Episode status menu
var $epMenu = null;
var _epMenuShowId = null;
var _epMenuCode = null;

function initEpActionMenu() {
    $epMenu = $('#ep-action-menu');
    $epMenu.find('.ep-menu-item').on('click', function() {
        var action = $(this).attr('data-action');
        $epMenu.hide();
        if (_epMenuShowId && _epMenuCode) {
            setEpisodeStatus(_epMenuShowId, _epMenuCode, action);
        }
    });
    $(document).on('click.epmenu', function(e) {
        if (!$(e.target).closest('#ep-action-menu, #season-action-menu').length) {
            $epMenu.hide();
            $('#season-action-menu').hide();
        }
    });
}

var $seasonMenu = null;
var _seasonMenuShowId = null;
var _seasonMenuCodes = null;

function initSeasonActionMenu() {
    $seasonMenu = $('#season-action-menu');
    $seasonMenu.find('.season-menu-item').on('click', function() {
        var action = $(this).attr('data-action');
        $seasonMenu.hide();
        if (_seasonMenuShowId && _seasonMenuCodes) {
            setEpisodeStatus(_seasonMenuShowId, _seasonMenuCodes.join(','), action);
        }
    });
}

function showSeasonMenu(showId, codes, $btn) {
    _seasonMenuShowId = showId;
    _seasonMenuCodes = codes;
    var off = $btn[0].getBoundingClientRect();
    var menuW = 200, winW = $(window).width();
    var left = Math.min(off.right - menuW, winW - menuW - 10);
    left = Math.max(left, 10);
    $seasonMenu.css({ top: off.bottom + 4, left: left }).show();
}

function showEpMenu(showId, code, $dot) {
    _epMenuShowId = showId;
    _epMenuCode = code;
    var off = $dot[0].getBoundingClientRect();
    var menuW = 170, winW = $(window).width();
    var left = Math.min(off.right - menuW, winW - menuW - 10);
    left = Math.max(left, 10);
    $epMenu.css({ top: off.bottom + 4, left: left }).show();
}

function setEpisodeStatus(showId, code, action) {
    var isBulk = code.indexOf(',') !== -1;
    stagehand.api('/api/shows/' + encodeURIComponent(showId) + '/episodes/' + encodeURIComponent(code) + '/status?value=' + action, {}, 'POST')
        .done(function(r) {
            var statuses = r.statuses || {};
            for (var epCode in statuses) {
                var icon = statuses[epCode][0], title = statuses[epCode][1];
                $('.ep-dot[data-ep-code="' + epCode + '"]')
                    .attr('class', 'ep-dot status-' + icon)
                    .attr('title', title + ' — click to change');
            }
            var label = action === 'need' ? 'Marked as Needed' : action === 'ignore' ? 'Marked as Ignored' : 'Deleted + Ignored';
            if (isBulk) {
                var count = Object.keys(statuses).length;
                notify(label, count + ' episode' + (count !== 1 ? 's' : '') + ' updated.', 'info');
            } else {
                notify(label, 'Episode ' + code + ' updated.', 'info');
            }
        })
        .fail(function(err) { notify('Status Change Failed', err.message, 'error'); });
}

function renderSeasons(seasons, showId) {
    var $c = $('#show-seasons').empty();
    if (!seasons.length) { $c.html('<p class="text-muted">No episodes found.</p>'); return; }

    for (var i = 0; i < seasons.length; i++) {
        var season = seasons[i];
        var label = season.number === 0 ? 'Specials' : 'Season ' + season.number;
        var haveCount = 0;
        var allCodes = [];
        for (var x = 0; x < season.episodes.length; x++) {
            if (season.episodes[x].status === 'have') haveCount++;
            allCodes.push(season.episodes[x].code);
        }
        var $hdr = $('<div>').addClass('season-header');
        $hdr.append($('<span>').html(label + ' <span class="text-muted" style="font-weight:normal;font-size:13px">(' + haveCount + '/' + season.episodes.length + ' downloaded)</span>'));
        var $menuBtn = $('<span>').addClass('season-menu-btn').attr('title', 'Season actions').html('&#8943;');
        (function(codes, $b) {
            $menuBtn.on('click', function(e) { e.stopPropagation(); showSeasonMenu(showId, codes, $b); });
        })(allCodes.slice(), $menuBtn);
        var $chevron = $('<i>').addClass('chevron down icon season-icon');
        $hdr.append($menuBtn).append($chevron);

        var $body = $('<div>').addClass('season-body');
        var $table = $('<table>').addClass('episode-table');
        for (var j = 0; j < season.episodes.length; j++) {
            var ep = season.episodes[j];
            var $tr = $('<tr>').attr('data-code', ep.code);
            $tr.append($('<td>').addClass('ep-num').text(ep.number));
            $tr.append($('<td>').text(ep.name || '(TBA)'));
            $tr.append($('<td>').addClass('ep-date').text(ep.airdate || 'TBA'));
            var $dot = $('<span>').addClass('ep-dot status-' + ep.status)
                .attr({ title: ep.status_title + ' — click to change', 'data-ep-code': ep.code })
                .html('&#9679;');
            (function($d, code) {
                $d.on('click', function(e) { e.stopPropagation(); showEpMenu(showId, code, $d); });
            })($dot, ep.code);
            $tr.append($('<td>').addClass('ep-status').append($dot));
            (function(code, name) {
                $tr.on('click', function() {
                    $.get(ROOT + '/api/shows/' + encodeURIComponent(showId) + '/' + code + '/overview', function(d) {
                        if (d.overview) notify(name || code, d.overview, 'info');
                    });
                });
            })(ep.code, ep.name);
            $table.append($tr);
        }
        $body.append($table);

        (function($b, $h, $ch) {
            $h.on('click', function() {
                if ($b.is(':visible')) {
                    $b.slideUp(150); $ch.removeClass('down').addClass('right');
                } else {
                    $b.slideDown(150); $ch.removeClass('right').addClass('down');
                }
            });
        })($body, $hdr, $chevron);

        if (i > 0) { $body.hide(); $chevron.removeClass('down').addClass('right'); }
        $c.append($hdr).append($body);
    }
}

// ---------------------------------------------------------------- Downloads
function loadDownloads() {
    var weeks = $('#dl-weeks-select').val() || '1';
    var status = $('#dl-status-select').val() || 'have';
    $('#downloads-content').html('<div style="text-align:center;padding:3rem"><div class="ui active inline loader"></div></div>');
    $.get(ROOT + '/api/downloads', { weeks: weeks, status: status }, function(data) {
        renderDownloads(data);
    }).fail(function() { notify('Error', 'Failed to load downloads.', 'error'); });
}

var WEEK_LABELS = ['This Week', 'Last Week', '2 Weeks Ago', '3 Weeks Ago', '4 Weeks Ago', '5 Weeks Ago', '6 Weeks Ago', '7 Weeks Ago'];
function weekLabel(w) {
    if (w === null || w === undefined) return 'Unknown Air Date';
    return w < WEEK_LABELS.length ? WEEK_LABELS[w] : w + ' Weeks Ago';
}

function renderDownloads(data) {
    var $c = $('#downloads-content').empty();
    var queue = data.queue || [], episodes = data.episodes || [];

    if (!queue.length && !episodes.length) {
        $c.html('<div class="text-muted" style="text-align:center;padding:3rem">No episodes match the selected criteria.</div>');
        return;
    }

    if (queue.length) {
        $c.append($('<div>').addClass('week-header').text('Queued Downloads'));
        var $qt = $('<table>').addClass('ui table dl-table');
        $qt.append('<thead><tr><th>Series</th><th>#</th><th>Episode</th><th>Date</th><th>Progress</th></tr></thead>');
        var $qb = $('<tbody>');
        queue.forEach(function(q) {
            var $tr = $('<tr>');
            $tr.append($('<td>').attr('title', q.show_name).append($('<a>').attr('href', '#/tv/' + q.show_id).css('color','#2185d0').text(q.show_name)));
            $tr.append($('<td>').text(q.season + 'x' + q.number));
            $tr.append($('<td>').attr('title', q.name).text(q.name));
            $tr.append($('<td>').css('white-space','nowrap').text(q.airdate || 'TBA'));
            var $prog;
            if (q.progress) {
                var barId = 'dlprog-' + q.show_id.replace(/[^a-zA-Z0-9]/g,'_') + '_' + q.code;
                $prog = $('<div>');
                $prog.append($('<div>').addClass('dl-progress-bar').attr('id', barId)
                    .append($('<div>').addClass('fill').css('width', q.progress.percentage + '%')));
                $prog.append($('<div>').css({fontSize:'11px',color:'#aaa',marginTop:'2px'})
                    .text(q.progress.current_mb + '/' + q.progress.total_mb + ' MB @ ' + q.progress.speed_kb + ' KB/s'));
            } else {
                $prog = $('<span>').css({color:'#888',fontSize:'12px'}).text('Queued');
            }
            $tr.append($('<td>').append($prog));
            $qb.append($tr);
        });
        $qt.append($qb);
        $c.append($qt);
    }

    if (episodes.length) {
        var lastWeek = undefined, $et = null;
        episodes.forEach(function(ep) {
            if (ep.week !== lastWeek) {
                lastWeek = ep.week;
                $c.append($('<div>').addClass('week-header').text(weekLabel(ep.week)));
                $et = $('<table>').addClass('ui table dl-table').css('margin-bottom','1rem');
                $et.append('<thead><tr><th>Series</th><th>#</th><th>Episode</th><th>Date</th><th>Status</th></tr></thead>');
                $et.append('<tbody>');
                $c.append($et);
            }
            var $tr = $('<tr>');
            $tr.append($('<td>').attr('title', ep.show_name).append($('<a>').attr('href', '#/tv/' + ep.show_id).css('color','#2185d0').text(ep.show_name)));
            $tr.append($('<td>').text(ep.season + 'x' + ep.number));
            $tr.append($('<td>').attr('title', ep.name).text(ep.name));
            $tr.append($('<td>').css('white-space','nowrap').text(ep.airdate || 'TBA'));
            $tr.append($('<td>').append($('<span>').addClass('status-' + ep.status).attr('title', ep.status_title).html('&#9679; ' + ep.status_title)));
            $et.find('tbody').append($tr);
        });
    }
}

// ---------------------------------------------------------------- Download progress update
var _dlQueueKey = '';
var _dlPollTimer = null;

function startDlPoll() {
    if (_dlPollTimer) return;
    _dlPollTimer = setInterval(function() {
        if ($('#view-downloads').hasClass('active')) silentReloadDownloads();
    }, 5000);
}
function stopDlPoll() {
    if (_dlPollTimer) { clearInterval(_dlPollTimer); _dlPollTimer = null; }
}

function silentReloadDownloads() {
    var weeks = $('#dl-weeks-select').val() || '1';
    var status = $('#dl-status-select').val() || 'have';
    $.get(ROOT + '/api/downloads', { weeks: weeks, status: status }, function(data) {
        renderDownloads(data);
    });
}

function onDlProgress(data) {
    var queue = data.queue || [];

    // Update nav progress bar
    if (!queue.length) {
        $('#nav-progress').hide();
    } else {
        var first = queue[0], prog = first[2];
        if (prog) {
            $('#nav-progress').show();
            try { $('#nav-progress-bar').progress({ percent: prog[0] }); } catch(e) {}
        }
    }

    // Detect queue composition changes (items added, finished, or reordered)
    var newKey = queue.map(function(i) { return i[0] + ':' + i[1]; }).join(',');
    if (newKey !== _dlQueueKey) {
        _dlQueueKey = newKey;
        if ($('#view-downloads').hasClass('active')) silentReloadDownloads();
        return;
    }

    // Same items — update progress bars in-place
    queue.forEach(function(item) {
        var showid = item[0], code = item[1], p = item[2];
        if (p) {
            var barId = '#dlprog-' + showid.replace(/[^a-zA-Z0-9]/g,'_') + '_' + code;
            $(barId).find('.fill').css('width', p[0] + '%');
            $(barId).next().text(p[1] + '/' + p[2] + ' MB @ ' + p[3] + ' KB/s');
        }
    });
}

// ---------------------------------------------------------------- Log view
var logSeq = 0;
var logTimer = null;
var logMinLevel = 0; // 0=all, 20=INFO, 30=WARNING
var LOG_LEVELS = { DEBUG2: 5, DEBUG: 10, INFO: 20, WARNING: 30, ERROR: 40, CRITICAL: 50 };
var LOG_COLORS = { DEBUG2: '#444', DEBUG: '#555', INFO: '#ccc', WARNING: '#f2711c', ERROR: '#db2828', CRITICAL: '#db2828' };

function startLogStream() {
    if (logTimer) return;
    fetchLog();
    logTimer = setInterval(fetchLog, 2000);
}

function stopLogStream() {
    if (logTimer) { clearInterval(logTimer); logTimer = null; }
}

function fetchLog() {
    $.get(ROOT + '/api/log', { since: logSeq }, function(data) {
        var records = data.records || [];
        var $out = $('#log-output');
        var atBottom = $out[0].scrollHeight - $out.scrollTop() - $out.outerHeight() < 40;

        records.forEach(function(r) {
            var lvl = LOG_LEVELS[r.level] || 0;
            if (lvl < logMinLevel) return;
            var color = LOG_COLORS[r.level] || '#ccc';
            var $line = $('<div>').css('color', color).text(r.msg);
            $out.append($line);
        });

        if (records.length) {
            logSeq = data.seq;
            // Trim to last 2000 lines to avoid unbounded DOM growth
            var lines = $out.children();
            if (lines.length > 2000) lines.slice(0, lines.length - 2000).remove();
        }

        if ($('#log-autoscroll').is(':checked') && (atBottom || records.length)) {
            $out[0].scrollTop = $out[0].scrollHeight;
        }

        var count = $out.children().length;
        $('#log-status').text('Showing ' + count + ' line' + (count !== 1 ? 's' : '') + ' · refreshes every 2s');
    }).fail(function() {
        $('#log-status').text('Connection error — retrying...');
    });
}

function setLogLevel(level) {
    logMinLevel = LOG_LEVELS[level] || 0;
    $('#log-level-filter .filter-btn').removeClass('active');
    $('#log-level-filter .filter-btn[data-level="' + (level || 'all') + '"]').addClass('active');
    // Re-render by resetting and re-fetching everything
    logSeq = 0;
    $('#log-output').empty();
    fetchLog();
}

// ---------------------------------------------------------------- Init
$(document).ready(function() {
    stagehand = new Stagehand(ROOT);
    stagehand.handle_response(INITIAL_ASYNC);
    stagehand.bind('dlprogress', onDlProgress);

    // Nav item clicks (prevent default, use hash nav)
    $('a.item[data-view]').on('click', function(e) {
        e.preventDefault();
        navigate('/' + $(this).attr('data-view'));
    });
    $('#nav-logo, #menu-label-logo').on('click', function() { navigate('/tv'); });

    // Light/dark theme toggle
    function applyThemeIcon() {
        var light = document.body.classList.contains('theme-light');
        $('#theme-toggle-icon').attr('class', light ? 'moon icon' : 'sun icon');
    }
    applyThemeIcon();
    $('#nav-theme-toggle').on('click', function() {
        var light = document.body.classList.toggle('theme-light');
        localStorage.setItem('stagehand-theme', light ? 'light' : 'dark');
        applyThemeIcon();
    });

    // Configure dropdown — manual impl to avoid Semantic UI .active class conflict
    var $cfgMenu = $('#nav-configure .menu');
    $('#nav-configure').on('click', function(e) {
        e.stopPropagation();
        $cfgMenu.toggle();
    });
    $(document).on('click.cfgmenu', function() { $cfgMenu.hide(); });

    // Filter buttons
    $('.filter-btn[data-filter]').on('click', function() { setFilter($(this).attr('data-filter')); });
    $('#btn-lib-grid').on('click', function() { setLibraryView('grid'); });
    $('#btn-lib-list').on('click', function() { setLibraryView('list'); });

    // Add show button
    $('#btn-add-show').on('click', function() { navigate('/tv/add'); });
    $('#btn-back-library').on('click', function() { navigate('/tv'); });
    $('#btn-back-from-show').on('click', function() { navigate('/tv'); });

    // General settings
    (function() {
        var saveTimer = null;
        var LOGLEVEL_OPTS = ['warn','info','debug','debug2'];
        var LOGLEVEL_LABELS = {'warn':'Warnings only','info':'Info','debug':'Debug','debug2':'Debug2'};

        function buildRadioGroup($container, name, opts, labels, val) {
            $container.empty();
            opts.forEach(function(o) {
                var $inp = $('<input>').attr({ type:'radio', name:name, id:name+'-'+o, value:o });
                if (o === val) $inp.prop('checked', true);
                var $lbl = $('<label>').attr('for', name+'-'+o).text(labels[o] || o);
                $container.append($inp).append($lbl);
            });
        }

        function loadGeneralSettings() {
            $.get(ROOT + '/api/settings/general', function(d) {
                $('#cfg-tvdir').val(d.tvdir || '');
                $('#cfg-language').val(d.language || '');
                $('#cfg-parallel').val(d.parallel || 1);
                $('#cfg-season-dir').val(d.season_dir_format || '');
                $('#cfg-ep-format').val(d.episode_format || '');
                $('#cfg-web-user').val(d.web_username || '');
                $('#cfg-web-pass').val(d.web_password || '');
                $('#cfg-en-user').val(d.easynews_username || '');
                $('#cfg-en-pass').val(d.easynews_password || '');
                buildRadioGroup($('#cfg-loglevel-group'), 'cfg-loglevel', LOGLEVEL_OPTS, LOGLEVEL_LABELS, d.loglevel || 'info');
                $('#cfg-rename').prop('checked', d.rename !== false);
                $('#cfg-naming-fields').toggle(d.rename !== false);
                $('input[name="cfg-sep"][value="' + (d.separator || '_') + '"]').prop('checked', true);
                var codeVal = d.code_style || '';
                var $codeMatch = $('input[name="cfg-code"][value="' + codeVal + '"]');
                if ($codeMatch.length) { $codeMatch.prop('checked', true); }
                else { $('input[name="cfg-code"]').prop('checked', false); }
                updateNamingPreview(d);
            });
        }

        function updateNamingPreview(d) {
            if (d && d.example) $('#cfg-naming-preview').text(d.example);
            else if (d && d.error) $('#cfg-naming-preview').text('Error: ' + d.error);
        }

        function showSectionStatus(sel, ok, msg) {
            $(sel).css('color', ok ? '#4caf50' : '#db2828').text(msg).show();
            setTimeout(function() { $(sel).fadeOut(400); }, 2000);
        }

        function postSettings(payload, statusSel) {
            $.ajax({ url: ROOT + '/api/settings/general', method: 'POST',
                contentType: 'application/json', data: JSON.stringify(payload) })
                .done(function(r) {
                    updateNamingPreview(r);
                    showSectionStatus(statusSel, true, 'Saved');
                })
                .fail(function() { showSectionStatus(statusSel, false, 'Save failed'); });
        }

        $('#btn-save-general').on('click', function() {
            postSettings({
                tvdir:    $('#cfg-tvdir').val(),
                language: $('#cfg-language').val(),
                loglevel: $('input[name="cfg-loglevel"]:checked').val(),
            }, '#general-status');
        });

        $('#btn-save-downloads').on('click', function() {
            postSettings({
                parallel: parseInt($('#cfg-parallel').val(), 10) || 1,
            }, '#downloads-status');
        });

        $('#cfg-rename').on('change', function() {
            $('#cfg-naming-fields').toggle(this.checked);
        });

        $('#btn-save-naming').on('click', function() {
            postSettings({
                rename:            $('#cfg-rename').prop('checked'),
                separator:         $('input[name="cfg-sep"]:checked').val() || '_',
                season_dir_format: $('#cfg-season-dir').val(),
                code_style:        $('input[name="cfg-code"]:checked').val() || '',
                episode_format:    $('#cfg-ep-format').val(),
            }, '#naming-status');
        });

        // Update naming preview live without saving
        function livePreview() {
            if (!$('#cfg-rename').prop('checked')) return;
            $.ajax({ url: ROOT + '/api/settings/general', method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    rename:            true,
                    separator:         $('input[name="cfg-sep"]:checked').val() || '_',
                    season_dir_format: $('#cfg-season-dir').val(),
                    code_style:        $('input[name="cfg-code"]:checked').val() || '',
                    episode_format:    $('#cfg-ep-format').val(),
                }) })
                .done(function(r) { updateNamingPreview(r); });
        }
        $('#cfg-season-dir, #cfg-ep-format').on('input', livePreview);
        $('input[name="cfg-sep"], input[name="cfg-code"]').on('change', livePreview);

        function credSave(userSel, passSel, statusSel, extra) {
            var user = $(userSel).val(), pass = $(passSel).val();
            var payload = $.extend({ web_username: '', web_password: '', easynews_username: '', easynews_password: '' }, extra(user, pass));
            $.ajax({ url: ROOT + '/api/settings/general', method: 'POST',
                contentType: 'application/json', data: JSON.stringify(payload) })
                .done(function() {
                    $(statusSel).text('Saved').show();
                    setTimeout(function() { $(statusSel).fadeOut(400); }, 2000);
                })
                .fail(function() { $(statusSel).css('color','#db2828').text('Save failed').show(); });
        }

        $('#btn-save-web-auth').on('click', function() {
            credSave('#cfg-web-user', '#cfg-web-pass', '#web-auth-status', function(u, p) {
                return { web_username: u, web_password: p };
            });
        });
        $('#btn-clear-web-auth').on('click', function() {
            $('#cfg-web-user, #cfg-web-pass').val('');
            credSave('#cfg-web-user', '#cfg-web-pass', '#web-auth-status', function() {
                return { web_username: '', web_password: '' };
            });
        });
        $('#btn-save-easynews').on('click', function() {
            credSave('#cfg-en-user', '#cfg-en-pass', '#easynews-status', function(u, p) {
                return { easynews_username: u, easynews_password: p };
            });
        });
        $('#btn-clear-easynews').on('click', function() {
            $('#cfg-en-user, #cfg-en-pass').val('');
            credSave('#cfg-en-user', '#cfg-en-pass', '#easynews-status', function() {
                return { easynews_username: '', easynews_password: '' };
            });
        });

        // Notifier settings (Home Assistant / Email / Kodi)
        function loadNotifierSettings() {
            $.get(ROOT + '/api/settings/notifiers', function(d) {
                $('#cfg-ha-enabled').prop('checked', !!d.homeassistant_enabled);
                $('#cfg-ha-url').val(d.homeassistant_url || '');
                $('#cfg-email-enabled').prop('checked', !!d.email_enabled);
                $('#cfg-email-host').val(d.email_hostname || '');
                $('#cfg-email-port').val(d.email_port || 587);
                $('#cfg-email-ssl').prop('checked', !!d.email_ssl);
                $('#cfg-email-user').val(d.email_username || '');
                $('#cfg-email-pass').val(d.email_password || '');
                $('#cfg-email-sender').val(d.email_sender || '');
                $('#cfg-email-recipients').val(d.email_recipients || '');
                $('#cfg-kodi-enabled').prop('checked', !!d.kodi_enabled);
                $('#cfg-kodi-host').val(d.kodi_hostname || '');
                $('#cfg-kodi-http-port').val(d.kodi_http_port || 8080);
                $('#cfg-kodi-user').val(d.kodi_username || '');
                $('#cfg-kodi-pass').val(d.kodi_password || '');
                $('#cfg-kodi-notify').prop('checked', !!d.kodi_notify);
                $('#cfg-kodi-individual').prop('checked', !!d.kodi_individual);
                $('#cfg-kodi-tvdir').val(d.kodi_tvdir || '');
            });
        }

        function postNotifierSettings(payload, statusSel) {
            $.ajax({ url: ROOT + '/api/settings/notifiers', method: 'POST',
                contentType: 'application/json', data: JSON.stringify(payload) })
                .done(function() { showSectionStatus(statusSel, true, 'Saved'); })
                .fail(function() { showSectionStatus(statusSel, false, 'Save failed'); });
        }

        $('#btn-save-ha').on('click', function() {
            postNotifierSettings({
                homeassistant_enabled: $('#cfg-ha-enabled').prop('checked'),
                homeassistant_url:     $('#cfg-ha-url').val(),
            }, '#ha-status');
        });

        $('#btn-save-email').on('click', function() {
            postNotifierSettings({
                email_enabled:    $('#cfg-email-enabled').prop('checked'),
                email_hostname:   $('#cfg-email-host').val(),
                email_port:       parseInt($('#cfg-email-port').val(), 10) || 587,
                email_ssl:        $('#cfg-email-ssl').prop('checked'),
                email_username:   $('#cfg-email-user').val(),
                email_password:   $('#cfg-email-pass').val(),
                email_sender:     $('#cfg-email-sender').val(),
                email_recipients: $('#cfg-email-recipients').val(),
            }, '#email-status');
        });

        $('#btn-save-kodi').on('click', function() {
            postNotifierSettings({
                kodi_enabled:    $('#cfg-kodi-enabled').prop('checked'),
                kodi_hostname:   $('#cfg-kodi-host').val(),
                kodi_http_port:  parseInt($('#cfg-kodi-http-port').val(), 10) || 8080,
                kodi_username:   $('#cfg-kodi-user').val(),
                kodi_password:   $('#cfg-kodi-pass').val(),
                kodi_notify:     $('#cfg-kodi-notify').prop('checked'),
                kodi_individual: $('#cfg-kodi-individual').prop('checked'),
                kodi_tvdir:      $('#cfg-kodi-tvdir').val(),
            }, '#kodi-status');
        });

        loadGeneralSettings();
        loadNotifierSettings();
    })();

    // Check hours checkboxes
    (function() {
        var $box = $('#hours-checkboxes');
        var $status = $('#hours-save-status');

        function buildCheckboxes(checked) {
            $box.empty();
            for (var h = 0; h < 24; h++) {
                var label = (h % 12 || 12) + (h < 12 ? 'am' : 'pm');
                var $cb = $('<input>').attr({ type: 'checkbox', id: 'hcb' + h, value: h });
                if (checked.indexOf(h) !== -1) $cb.prop('checked', true);
                var $lbl = $('<label>').addClass('text-soft').css({
                    display: 'flex', alignItems: 'center', gap: '4px',
                    fontSize: '13px', cursor: 'pointer'
                }).attr('for', 'hcb' + h).append($cb).append(document.createTextNode(label));
                $box.append($lbl);
            }
        }

        function getChecked() {
            return $box.find('input:checked').map(function() { return +this.value; }).get();
        }

        function saveHours() {
            $.ajax({ url: ROOT + '/api/settings/check-hours', method: 'POST',
                contentType: 'application/json', data: JSON.stringify({ hours: getChecked() }) })
                .done(function() {
                    $status.css('color', '#4caf50').text('Saved').show();
                    setTimeout(function() { $status.fadeOut(400); }, 2000);
                })
                .fail(function() { $status.css('color', '#db2828').text('Save failed').show(); });
        }

        $.get(ROOT + '/api/settings/check-hours', function(d) { buildCheckboxes(d.hours || []); });

        $('#hours-all').on('click', function() { $box.find('input').prop('checked', true); });
        $('#hours-none').on('click', function() { $box.find('input').prop('checked', false); });
        $('#hours-every2').on('click', function() {
            $box.find('input').each(function() { $(this).prop('checked', this.value % 2 === 0); });
        });
        $('#hours-every4').on('click', function() {
            $box.find('input').each(function() { $(this).prop('checked', this.value % 4 === 0); });
        });
        $('#btn-save-hours').on('click', saveHours);
    })();

    // Downloads controls
    $('#dl-status-select, #dl-weeks-select').on('change', loadDownloads);
    $('#upcoming-days-select').on('change', loadUpcoming);
    $('#btn-check-episodes, #btn-check-all').on('click', function() {
        var $b = $(this).prop('disabled', true);
        stagehand.api('/api/shows/check')
            .always(function() { $b.prop('disabled', false); })
            .done(function(r) { notify('Check Complete', 'Need: ' + (r.need||0) + ', Found: ' + (r.found||0), 'info'); })
            .fail(function(err) { notify('Error', err.message, 'error'); });
    });

    // Advanced settings toggle
    $('#show-advanced-toggle').on('click', function() {
        var $adv = $('#show-advanced'), $icon = $('#show-adv-icon');
        if ($adv.is(':visible')) {
            $adv.slideUp(200); $icon.removeClass('down').addClass('right');
        } else {
            $adv.slideDown(200); $icon.removeClass('right').addClass('down');
        }
    });

    // Modal cancel
    $('#modal-delete-cancel').on('click', function() { $('#modal-delete').modal('hide'); });

    // Nav search shortcut
    $('#nav-search-icon').on('click', function() { $('#nav-search-input').focus(); });
    $('#nav-search-input').on('keydown', function(e) {
        if (e.keyCode === 13) {
            var q = $(this).val().trim();
            if (q) {
                $(this).val('');
                navigate('/tv/add');
                setTimeout(function() {
                    $('#add-search-input').val(q);
                    $('#add-search-btn').click();
                }, 100);
            }
        }
    });

    // Log controls
    $('#log-level-filter .filter-btn').on('click', function() {
        var level = $(this).attr('data-level');
        setLogLevel(level === 'all' ? null : level);
    });
    $('#log-clear-btn').on('click', function() {
        $('#log-output').empty();
        $('#log-status').text('Cleared');
    });

    initAddShow();
    initEpActionMenu();
    initSeasonActionMenu();
    window.addEventListener('hashchange', route);
    route();
});

})();
</script>
</body>
</html>
